# Canvas Credentials (optional - only for CLI mode)
CANVAS_USERNAME=your_flashline_id
CANVAS_PASSWORD=your_password

# Google OAuth (required for web app)
GOOGLE_CLIENT_ID=your_google_client_id_from_console
GOOGLE_CLIENT_SECRET=your_google_client_secret

# PostgreSQL Database (required for production)
DATABASE_URL=postgresql://user:password@host:5432/canvas_db

# Flask Secret Key (auto-generated if not set, but set for consistency across deploys)
FLASK_SECRET_KEY=your_secret_key_hex_string

# AI APIs
OPENAI_API_KEY=your_openai_api_key_for_quiz_solving
ANTHROPIC_API_KEY=your_anthropic_api_key_for_assignment_completion

# Optional
ADMIN_PASSWORD=admin1234
HEADLESS_BROWSER=true
RAILWAY_ENVIRONMENT=production
