{
  "manifest_version": 3,
  "name": "Canvas AI Helper",
  "version": "1.0.0",
  "description": "Generate AI-powered assignment drafts directly from your Canvas assignments",
  "author": "Canvas AI",
  "homepage_url": "https://canvas-ai.herokuapp.com",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.instructure.com/*",
    "*://*.kent.instructure.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Canvas AI Helper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "settings.html",
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.instructure.com/*", "*://*.kent.instructure.com/*"],
      "js": ["js/content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "settings.html"],
      "matches": ["*://*.instructure.com/*", "*://*.kent.instructure.com/*"]
    }
  ]
}
